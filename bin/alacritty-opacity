#!/usr/bin/env python3

import json
import subprocess
import sys

def get_opacity():
    result = subprocess.run(
        ["alacritty", "msg", "get-config"],
        capture_output=True, text=True, check=True,
    )
    config = json.loads(result.stdout)
    return config.get("window", {}).get("opacity", 1.0)

def set_opacity(value):
    value = round(max(0.0, min(1.0, value)), 2)
    subprocess.run(
        ["alacritty", "msg", "config", f"window.opacity={value}"],
        check=True,
    )

opacity = get_opacity()
try:
    change = float(sys.argv[1])
except:
    print(f"Usage: {sys.argv[0]} <change>", file=sys.stderr)
    sys.exit(1)

set_opacity(opacity + change)
